<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:orientation="vertical"
        android:gravity="center"
        android:padding="16dp"
        android:background="#E3F2FD">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="AJOUTER UNE ROUTE"
            android:textSize="18sp"
            android:textStyle="bold"
            android:layout_marginBottom="16dp" />

        <Button
            android:id="@+id/btnAjouterRoute"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Ajouter une route" />

        <TextView
            android:id="@+id/txtMessageAjout"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text=""
            android:textColor="#4CAF50"
            android:textStyle="bold"
            android:layout_marginTop="16dp"
            android:visibility="gone" />
    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:orientation="vertical"
        android:gravity="center"
        android:padding="16dp"
        android:background="#FFEBEE">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="SUPPRIMER UNE ROUTE"
            android:textSize="18sp"
            android:textStyle="bold"
            android:layout_marginBottom="16dp" />

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <EditText
                android:id="@+id/edtNumeroRoute"
                android:layout_width="150dp"
                android:layout_height="wrap_content"
                android:minHeight="48dp"
                android:hint="Numéro de route"
                android:inputType="number" />

            <Button
                android:id="@+id/btnSupprimerRoute"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Supprimer"
                android:layout_marginStart="8dp" />
        </LinearLayout>

        <TextView
            android:id="@+id/txtMessageSuppression"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text=""
            android:textColor="#F44336"
            android:textStyle="bold"
            android:layout_marginTop="16dp"
            android:visibility="gone" />
    </LinearLayout>

    <Button
        android:id="@+id/btnRetourMenu"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Retour au menu"
        android:backgroundTint="#607D8B" />

</LinearLayout>